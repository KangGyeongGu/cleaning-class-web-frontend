{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/lint-format-check.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d node_modules || npm install --ignore-scripts 2>/dev/null"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/verify-build.sh"
          }
        ]
      }
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Skill(w-plan)",
      "Skill(w-develop)",
      "Skill(w-audit)",
      "Skill(w-verify)",
      "Skill(w-review)",
      "Skill(w-browser-test)",
      "Skill(frontend-design)",
      "Skill(teach-impeccable)",
      "Skill(typeset)",
      "Skill(arrange)",
      "Skill(adapt)",
      "Skill(polish)"
    ]
  }
}
